@{
    ViewData["Title"] = "Add Product";
}

@model InventoryApp.ViewModels.AddProductViewModel;

@section Styles {
    <link rel="stylesheet" href="~/css/products/Product.css" asp-append-version="true" />
}

<div>
    <div class="d-flex align-items-center justify-content-between">
        <h4 class="title mb-0">Add Product</h4>
        <a class="btn btn-outline-secondary" asp-action="Index">
            Product List
        </a>
    </div>
 
    <form asp-action="Add" method="post" enctype="multipart/form-data">

        <div class="container popUp bg-white mt-3 rounded-3 p-4">
            <div class="cont-title">
                <p>Product Detail</p>
            </div>

            <div class="row">
                <!--left col-->
                <div class="col-md-6">
                    <!--product code-->
                    <div class="mb-2">
                        <label asp-for="ProductCode" class="form-label"></label>
                        <input asp-for="ProductCode" class="form-control" />
                        <span asp-validation-for="ProductCode" class="text-danger"></span>
                    </div>
                    <!--name-->
                    <div class="mb-2">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <!--description-->
                    <div class="mb-2">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <!--is active-->
                    <div>
                        <label asp-for="IsActive" class="form-label"></label>
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>

                </div>
                <!--right col-->
                <div class="col-md-6">
                    <!--image-->
                    <div>
                        <label asp-for="Image" class="form-label"></label>

                        <div class="img-thumbnail d-flex justify-content-center align-items-center"
                             style="width:100%; height:200px;">

                            <img src="~/images/default-img.jpg"
                                 style="width:180px; height:150px; object-fit:cover;" />
                        </div>

                        <input asp-for="Image" class="form-control" />
                        <span asp-validation-for="Image" class="text-danger"></span>
                    </div>

                </div>

            </div>
        </div>

        <div class="container popUp bg-white mt-1 rounded-3 p-4">

            <div class="cont-title">
                <p>Category</p>
            </div>

            <div class="row gy-2">

                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <input asp-for="CategoryId" class="form-control" />
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <input asp-for="CategoryId" class="form-control" />
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label">Description</label>
                    <input asp-for="CategoryId" class="form-control" />
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

            </div>
        </div>

        <div class="container popUp bg-white mt-1 rounded-3 p-4">

            <div class="cont-title">
                <p>Price</p>
            </div>

            <div class="row gy-2">

                <div class="col-md-6">
                    <label asp-for="CostPrice" class="form-label"></label>
                    <input asp-for="CostPrice" class="form-control" />
                    <span asp-validation-for="CostPrice" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SellingPrice" class="form-label"></label>
                    <input asp-for="SellingPrice" class="form-control" />
                    <span asp-validation-for="SellingPrice" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StockQuantity" class="form-label"></label>
                    <input asp-for="StockQuantity" class="form-control" />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StockQuantity" class="form-label"></label>
                    <input asp-for="StockQuantity" class="form-control" />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LowStackTreshold" class="form-label"></label>
                    <input asp-for="LowStackTreshold" class="form-control" />
                    <span asp-validation-for="LowStackTreshold" class="text-danger"></span>
                </div>

            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-secondary">Submit</button>
        </div>

    </form>
</div>