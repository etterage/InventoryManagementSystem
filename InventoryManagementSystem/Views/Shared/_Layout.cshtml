<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/InventoryApp.styles.css" asp-append-version="true" />
    
    @* CSS *@
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/products/product-list.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    @* Icon *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    @* Toast CSS *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

</head>
<body>
    
    <div class="d-flex">

        @* Sidebar *@
        <div class="sidebar d-flex flex-column p-3">
           
            @* Logo *@
            <h4 class="text-white mb-5">Inventor.io</h4>

            @* Nav Links *@
            <ul class="nav nav-pills flex-column gap-2 mt-2">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="dashboard" asp-action="index">
                        <i class="bi bi-speedometer2 me-2"></i>
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-bag me-2"></i>
                        Products
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-tags me-2"></i>
                        Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-currency-dollar me-2"></i>
                        Sales
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-cart-plus me-2"></i>
                        Purchases
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>
                        Returns
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-people me-2"></i>
                        People
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-bar-chart-line me-2"></i>
                        Reports
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-gear me-2"></i>
                        Settings
                    </a>
                </li>
            </ul>

            @* Logout Button *@
            <div class="mt-auto">
                <a class="btn btn-outline-light w-100 text-white"
                   asp-controller="Account" asp-action="Logout">
                    Logout
                </a>
            </div>

        </div>

        @* Nav Bar *@
        <div class="flex-grow-1">
            <nav class="navbar bg-white px-4 d-flex justify-content-end popUp">
                <div class="d-flex gap-3">
                    <i class="bi bi-envelope"></i>
                    <i class="bi bi-bell"></i>
                    <div>M</div>
                </div>
            </nav>

            @* Content *@
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
        
    </div>

    

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Toast *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
